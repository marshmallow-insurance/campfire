{
  "name": "@mrshmllw/campfire",
  "version": "6.0.0",
  "description": "Collection of toasty utils and configs used by Marshmallow Technology",
  "type": "module",
  "scripts": {
    "clean": "rimraf ./dist",
    "test": "vitest run",
    "check-types": "concurrently --group \"npm run check-tsc\" \"npm run lint\" -s all --timings true",
    "check-tsc": "tsc --noEmit",
    "lint": "eslint .",
    "build": "npm run clean && tsc --p tsconfig.build.json",
    "prepublishOnly": "npm run build",
    "prepare": "husky",
    "pre-commit-lint": "npm run check-types && lint-staged",
    "commitlint": "commitlint --edit"
  },
  "exports": {
    "./configs/*": {
      "types": "./dist/configs/*.d.ts",
      "import": "./dist/configs/*.js"
    },
    "./utils/*": {
      "types": "./dist/utils/*.d.ts",
      "import": "./dist/utils/*.js"
    },
    "./workflows/*": "./dist/workflows/*"
  },
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "@commitlint/cli": "^20",
    "@commitlint/types": ">=20",
    "conventional-changelog-conventionalcommits": ">=9",
    "@semantic-release/changelog": ">=6",
    "@semantic-release/git": ">=10",
    "@typescript-eslint/eslint-plugin": ">=8",
    "@typescript-eslint/parser": ">=8",
    "eslint": "^9 || ^10",
    "eslint-config-prettier": "^9 || >=10",
    "eslint-plugin-prettier": "^4 || >=5",
    "husky": "^9",
    "lint-staged": "^15 || ^16",
    "prettier": "^3",
    "semantic-release": ">=25"
  },
  "peerDependenciesMeta": {
    "@commitlint/cli": {
      "optional": true
    },
    "@commitlint/types": {
      "optional": true
    },
    "conventional-changelog-conventionalcommits": {
      "optional": true
    },
    "@semantic-release/changelog": {
      "optional": true
    },
    "@semantic-release/git": {
      "optional": true
    },
    "@typescript-eslint/eslint-plugin": {
      "optional": true
    },
    "@typescript-eslint/parser": {
      "optional": true
    },
    "eslint": {
      "optional": true
    },
    "eslint-config-prettier": {
      "optional": true
    },
    "eslint-plugin-prettier": {
      "optional": true
    },
    "prettier": {
      "optional": true
    },
    "husky": {
      "optional": true
    },
    "lint-staged": {
      "optional": true
    },
    "semantic-release": {
      "optional": true
    }
  },
  "devDependencies": {
    "@commitlint/cli": "^20.1.0",
    "@commitlint/types": "^20.0.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.47.0",
    "@typescript-eslint/parser": "^8.47.0",
    "@typescript-eslint/rule-tester": "^8.47.0",
    "@typescript-eslint/utils": "^8.49.0",
    "concurrently": "^9.2.1",
    "conventional-changelog-conventionalcommits": "^9.1.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.6",
    "prettier": "^3.6.2",
    "rimraf": "^6.1.0",
    "semantic-release": "^25.0.3",
    "typescript": "^6.0.2",
    "vitest": "^4.0.10"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/marshmallow-insurance/campfire.git"
  },
  "author": "",
  "license": "ISC"
}
